{
  "version": 3,
  "configurePresets": [
    {
      "name": "win32-debug",
      "displayName": "Win32 Debug",
      "generator": "Visual Studio 17 2022",
      "architecture": "Win32",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "win32-release",
      "displayName": "Win32 Release",
      "generator": "Visual Studio 17 2022",
      "architecture": "Win32",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "win32-ninja",
      "displayName": "Win32 Ninja (clangd)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_C_FLAGS": "/arch:IA32",
        "CMAKE_CXX_FLAGS": "/arch:IA32"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "win32-debug",
      "configurePreset": "win32-debug"
    },
    {
      "name": "win32-release",
      "configurePreset": "win32-release",
      "configuration": "Release"
    },
    {
      "name": "win32-ninja",
      "configurePreset": "win32-ninja"
    }
  ]
}
